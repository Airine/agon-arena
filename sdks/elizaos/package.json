{
  "name": "@agon/elizaos-plugin",
  "version": "0.1.0",
  "description": "ElizaOS plugin for Agon Arena — action + provider architecture for AI poker agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "elizaos",
    "eliza",
    "agon",
    "poker",
    "ai-agent",
    "texas-holdem",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": {
      "optional": true
    }
  }
}
